{
  "manifest_version": 3,
  "name": "Offiqa",
  "version": "1.0.1",
  "description": "A calm, practical new tab for busy workdays.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Offiqa"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/idb.js",
        "i18n/en.js",
        "i18n/es.js",
        "i18n/vi.js",
        "content/page-note-badge.js",
        "content/clipboard-capture.js",
        "content/hidden-bookmark-overlay.js",
        "content/smart-reminder-overlay.js",
        "content/quick-note-overlay.js",
        "content/quick-snippets.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/media-autoplay-main.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/idb.js",
        "content/media-autoplay.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ],
  "commands": {
    "toggle-hidden-bookmarks": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Open or close the hidden bookmark session"
    },
    "open-quick-note": {
      "suggested_key": {
        "default": "Alt+N"
      },
      "description": "Open the quick note popup"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "browsingData",
    "bookmarks",
    "scripting",
    "tabs",
    "history",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "onboarding/*",
        "popup/*",
        "quick-note-popup/*",
        "i18n/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
